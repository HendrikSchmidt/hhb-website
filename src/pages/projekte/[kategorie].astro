---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { categories } from '../../lib/categories';
import { withBase } from '../../lib/url';

export async function getStaticPaths() {
  return categories.map(cat => ({ params: { kategorie: cat.slug } }));
}

const { kategorie } = Astro.params;
const cat = categories.find(c => c.slug === kategorie)!;

const allProjects = await getCollection('projects');
const projects = allProjects
  .filter(p => p.data.category === kategorie)
  .sort((a, b) => a.data.order - b.data.order);
---

<BaseLayout title={cat.title}>
  <nav><a href={withBase('/')}>← Übersicht</a></nav>

  <h1>{cat.title}</h1>

    {projects.length === 0 && <p class="empty">Keine Projekte vorhanden.</p>}

    <ul class="project-list">
      {projects.map(p => (
        <li>
          <a href={withBase(`/projekte/${kategorie}/${p.id}`)}>
            <div class="project-image">
              <img
                src={withBase(p.data.cover)}
                alt={p.data.title}
                loading="lazy"
              />
            </div>
            <div class="project-info">
              <span class="project-title">{p.data.title}</span>
              <span class="project-year">{p.data.year}</span>
            </div>
          </a>
        </li>
      ))}
  </ul>
</BaseLayout>

<style>
  nav {
    margin-bottom: 2rem;
    font-size: 0.85rem;
    color: var(--text-muted);
  }

  nav a:hover {
    text-decoration: underline;
  }

  h1 {
    font-size: 1.4rem;
    font-weight: 400;
    color: var(--blue-highlight);
    margin-bottom: 2rem;
  }

  .empty {
    font-size: 0.9rem;
    color: var(--text-muted);
  }

  .project-list {
    list-style: none;
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 2rem;
  }

  .project-list a {
    display: block;
    color: var(--text);
  }

  .project-image {
    width: 100%;
    aspect-ratio: 4 / 3;
    overflow: hidden;
    margin-bottom: 0.6rem;
  }

  .project-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.3s ease;
  }

  .project-list a:hover .project-image img {
    transform: scale(1.03);
  }

  .project-info {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: 0.5rem;
  }

  .project-title {
    font-size: 0.9rem;
    font-weight: 400;
  }

  .project-year {
    font-size: 0.8rem;
    color: var(--text-muted);
    white-space: nowrap;
  }
</style>
