---
import BaseLayout from './BaseLayout.astro';
import { withBase } from '../lib/url';
import { categories } from '../lib/categories';

interface Props {
  title: string;
  category: string;
  location: string;
  year: string;
  type: string;
  facts: string[];
  cover: string;
  images: string[];
}

const { title, category, location, year, type, facts, cover, images } = Astro.props;

const cat = categories.find(c => c.slug === category);
const allImages = [cover, ...images];
---

<BaseLayout title={title}>
  <nav>
    <a href={withBase('/')}>← Übersicht</a>
    {cat && <span> / <a href={withBase(`/projekte/${cat.slug}`)}>{cat.title}</a></span>}
  </nav>

  <article>
      <header>
        <h1>{title}</h1>
        <p class="meta">{location} &nbsp;·&nbsp; {year} &nbsp;·&nbsp; {type}</p>
      </header>

      <ul class="facts">
        {facts.map(f => <li>{f}</li>)}
      </ul>

      <div class="prose">
        <slot />
      </div>

      {allImages.length > 0 && (
        <div class="gallery">
          {allImages.map((src, i) => (
            <img
              src={withBase(src)}
              alt={`${title} – Bild ${i + 1}`}
              loading={i === 0 ? 'eager' : 'lazy'}
            />
          ))}
        </div>
      )}
  </article>
</BaseLayout>

<style>
  nav {
    margin-bottom: 2rem;
    font-size: 0.85rem;
    color: var(--text-muted);
  }

  nav a:hover {
    text-decoration: underline;
  }

  header {
    margin-bottom: 1.5rem;
  }

  h1 {
    font-size: 1.4rem;
    font-weight: 400;
    color: var(--blue-highlight);
    margin-bottom: 0.35rem;
  }

  .meta {
    font-size: 0.85rem;
    color: var(--text-muted);
  }

  .facts {
    list-style: none;
    margin-bottom: 2rem;
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
  }

  .facts li {
    font-size: 0.85rem;
    line-height: 1.6;
    padding-left: 1rem;
    position: relative;
    color: var(--text);
  }

  .facts li::before {
    content: '–';
    position: absolute;
    left: 0;
    color: var(--text-muted);
  }

  .prose {
    font-size: 0.95rem;
    line-height: 1.75;
    color: var(--text);
    margin-bottom: 2.5rem;
  }

  .prose :global(p) {
    margin-bottom: 1rem;
  }

  .gallery {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
    gap: 0.75rem;
  }

  .gallery img {
    width: 100%;
    aspect-ratio: 4 / 3;
    object-fit: cover;
  }

  @media (max-width: 600px) {
    .gallery {
      grid-template-columns: 1fr;
    }
  }
</style>
