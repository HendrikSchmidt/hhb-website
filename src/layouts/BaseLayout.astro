---
import '../styles/global.css';
import { withBase } from '../lib/url';

interface Props {
  title?: string;
  centered?: boolean;
}
const { title = 'hhb architekten', centered = false } = Astro.props;
---

<html lang="de">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href={withBase('/favicon.svg')} />
    <link rel="icon" href={withBase('/favicon.ico')} />
    <title>{title === 'hhb architekten' ? title : `${title} – hhb architekten`}</title>
  </head>
  <body>
    <main class:list={{ centered }}>
      <slot />
    </main>
    <footer>
      <a href={withBase('/impressum')}>Impressum</a>
    </footer>
  </body>
</html>

<style>
  body {
    display: grid;
    grid-template-rows: 1fr auto;
    min-height: 100vh;
  }

  main {
    align-self: start;
    width: 100%;
    max-width: var(--content-max-width);
    margin-inline: auto;
    padding: 3rem var(--page-padding-x);
  }

  main.centered {
    align-self: stretch;
    max-width: none;
    margin-inline: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 2rem 1rem;
  }

  footer {
    width: 100%;
    max-width: var(--content-max-width);
    margin-inline: auto;
    padding: 1rem var(--page-padding-x);
    text-align: right;
    font-size: 0.75rem;
    color: var(--text-muted);
  }

  @media (max-width: 600px) {
    main {
      padding-block: 2rem;
    }
  }

  footer a:hover {
    text-decoration: underline;
  }
</style>
