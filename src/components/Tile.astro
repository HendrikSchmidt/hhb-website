---
interface Props {
  title: string;
  href: string;
  accent?: string;
  highlightTitle?: boolean;
}
const { title, href, accent, highlightTitle } = Astro.props;
---

<a class="tile" href={href} style={accent ? `--accent: ${accent}` : undefined}>
  <span class:list={['tile-title', { highlighted: highlightTitle }]}>{title}</span>
</a>

<style>
  .tile {
    display: block;
    position: relative;
    width: 100%;
    aspect-ratio: 1 / 1;
    border: 2px solid var(--text);
    background: var(--bg);
    transition: background 0.15s ease;
  }

  .tile:hover {
    background: var(--blue-highlight-bg);
  }

  .tile-title {
    position: absolute;
    bottom: 0.6rem;
    left: 0.7rem;
    font-size: clamp(0.8rem, 1.4vw, 1.2rem);
    font-weight: 400;
    color: var(--text);
    letter-spacing: 0.01em;
    line-height: 1.2;
  }

  .tile-title.highlighted {
    font-weight: 600;
    color: var(--blue-highlight);
  }
</style>
